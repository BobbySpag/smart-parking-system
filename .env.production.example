# =============================================================================
# Smart Parking System – Production Environment Variables
# =============================================================================
# Copy this file to .env (never commit the real .env to version control).
# Replace every placeholder value with a real value before deploying.
# =============================================================================

# --- Database -----------------------------------------------------------
# Full async-compatible PostgreSQL connection string.
# Replace host, port, user, password, and database name with your cloud DB values.
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# --- JWT / Security -----------------------------------------------------
# IMPORTANT: Generate a strong random secret key for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse the development key in production.
SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-32-chars

# JWT signing algorithm – HS256 is recommended for symmetric keys.
ALGORITHM=HS256

# Token lifetime in minutes (default 30 = 30 minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Application --------------------------------------------------------
# Set DEBUG to false in production to avoid leaking stack traces.
DEBUG=false

# --- Frontend -----------------------------------------------------------
# Full URL of the deployed backend API (no trailing slash).
# Used by the React app to make API requests.
REACT_APP_API_URL=https://your-backend-domain.example.com

# Optional: Mapbox public token for map tiles (safe to expose in client code).
REACT_APP_MAPBOX_TOKEN=pk.replace_with_your_mapbox_public_token
